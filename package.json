{
  "name": "commconsole",
  "version": "1.4.0",
  "description": "CommConsole — secure SSH, serial/COM, and SFTP terminal client",
  "main": "out/main/index.js",
  "author": "Derrick Frey",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "predist": "node scripts/setup-wcs.mjs",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable",
    "dist:folder": "npm run build && electron-packager . CommConsole --platform=win32 --arch=x64 --out=dist --overwrite --icon=assets/icon.ico --ignore=src --ignore=node_modules/.cache",
    "make-icon": "node scripts/make-icon.mjs",
    "rebuild": "electron-rebuild -f -w serialport",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "serialport": "^13.0.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/packager": "^20.0.1",
    "@electron/rebuild": "^4.0.4",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.1",
    "to-ico": "^1.1.5",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.commconsole.app",
    "productName": "CommConsole",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "CommConsole-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "CommConsole-${version}-Setup.exe"
    }
  }
}
